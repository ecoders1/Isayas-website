{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin/index.html"
    },
    {
      "src": "/admin/dashboard",
      "dest": "/admin/dashboard.html"
    },
    {
      "src": "/lectures",
      "dest": "/lectures/all.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
